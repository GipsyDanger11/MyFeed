# MyFeed automation worker — example env for local dev
# Copy to .env (gitignored) and fill in real values for local testing.
# In production, set these in Railway → Variables.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...service-role-key...
ENCRYPTION_KEY=myfeed-dev-encryption-key-change-me-please-32b

# Optional tuning
WORKER_INTERVAL_SECONDS=1800
MAX_LIKES_PER_DAY=30
MAX_FOLLOWS_PER_DAY=10
DELAY_MIN_SECONDS=8
DELAY_MAX_SECONDS=30
LOG_LEVEL=INFO
PORT=8000
